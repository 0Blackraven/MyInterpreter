fun fib(n) {
  if (n < 2) return n;
  return fib(n - 1) + fib(n - 2);
}

var before = clock();
print fib(30);
var after = clock();

print "Elapsed time:";
print after - before;

let sum = 0;
for (let i = 0; i < 10000000; i = i + 1) {
  sum = sum + i;
}
print sum;

let sum = 0;
for (let i = 0; i < 10; i = i + 1) {
  sum = sum + i;
}
print sum;
